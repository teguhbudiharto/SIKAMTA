@model SIKAMTA.Models.TransaksiKas

@{
    Layout = "_AdminLayout";
}

<h2>Tambah Transaksi Kas</h2>

<hr />

<form method="post">

    <div class="mb-3">
    <label asp-for="Tanggal" class="form-label">Tanggal Transaksi</label>
    
    <input asp-for="Tanggal" 
           type="date" 
           class="form-control" 
           onclick="this.showPicker()" 
           value="@DateTime.Now.ToString("yyyy-MM-dd")" 
           style="cursor: pointer;" 
           required />
           
    <span asp-validation-for="Tanggal" class="text-danger"></span>
</div>

    <div class="mb-3">

        <label>Kategori</label>

        <select asp-for="KategoriId"
                class="form-control">

            @foreach(var item in ViewBag.Kategori)
            {
                <option value="@item.Id">
                    @item.NamaKategori
                </option>
            }

        </select>

    </div>

    <div class="mb-3">

        <label>Jenis</label>

        <select asp-for="Jenis"
                class="form-control">

            <option value="Masuk">
                Masuk
            </option>

            <option value="Keluar">
                Keluar
            </option>

        </select>

    </div>

    <div class="mb-3">

        <label>Keterangan</label>

        <textarea asp-for="Keterangan"
                  class="form-control"></textarea>

    </div>

    <div class="mb-3">

        <label>Nominal</label>

        <input asp-for="Nominal"
               class="form-control" />

    </div>

    <button type="submit"
            class="btn btn-success">
        Simpan
    </button>

</form>