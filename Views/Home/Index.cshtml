@model SIKAMTA.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Beranda Publik";
}

<div class="container py-5">
    <div class="p-5 mb-4 text-white rounded-4 shadow" style="background: linear-gradient(135deg, #198754 0%, #146c43 100%);">
        <div class="container-fluid py-3 text-center">
            <div class="mb-3">
                <img src="@Model.LogoPath" alt="Logo Mushola" class="bg-white rounded-circle p-2 shadow" style="width: 100px; height: 100px; object-fit: cover;" onerror="this.src='/images/default-logo.png';" />
            </div>
            
            <h1 class="display-5 fw-bold mb-0">Sistem Informasi Kas</h1>
            <h2 class="display-4 fw-bold text-warning mb-3">@Model.NamaMushola</h2>
            
            <hr class="border-light opacity-50 w-50 mx-auto" />
            
            <p class="fs-5 mb-1"><i class="text-warning">📍</i> @Model.Alamat</p>
        </div>
    </div>

    <div class="row align-items-md-stretch justify-content-center mb-5">
        <div class="col-md-10">
            <div class="h-100 p-4 bg-white border rounded-4 text-center shadow-sm">
                <h4 class="text-success fw-bold mb-3">Selamat Datang</h4>
                <p class="text-muted fs-6 px-md-5 mb-0">
                    Sistem ini didedikasikan untuk mengelola pencatatan pemasukan, pengeluaran, dan pelaporan keuangan mushola secara terbuka, akuntabel, dan profesional demi kenyamanan jamaah.
                </p>
            </div>
        </div>
    </div>

    <div class="row justify-content-center g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 text-center p-4" style="border-bottom: 5px solid #0d6efd;">
                <div class="text-primary mb-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor" class="bi bi-box-arrow-in-down" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M3.5 6a.5.5 0 0 0-.5.5v8a.5.5 0 0 0 .5.5h9a.5.5 0 0 0 .5-.5v-8a.5.5 0 0 0-.5-.5h-2a.5.5 0 0 1 0-1h2A1.5 1.5 0 0 1 14 6.5v8a1.5 1.5 0 0 1-1.5 1.5h-9A1.5 1.5 0 0 1 2 14.5v-8A1.5 1.5 0 0 1 3.5 5h2a.5.5 0 0 1 0 1h-2z"/>
                        <path fill-rule="evenodd" d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z"/>
                    </svg>
                </div>
                <h6 class="text-muted text-uppercase fw-bold mb-1">Total Pemasukan</h6>
                <h3 class="fw-bold text-dark mb-0">Rp @Model.TotalMasuk.ToString("N0")</h3>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow rounded-4 text-center p-4 bg-success text-white" style="transform: scale(1.05); z-index: 1;">
                <div class="text-warning mb-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-safe2" viewBox="0 0 16 16">
                        <path d="M1 1.5A1.5 1.5 0 0 1 2.5 0h12A1.5 1.5 0 0 1 16 1.5v13a1.5 1.5 0 0 1-1.5 1.5h-12A1.5 1.5 0 0 1 1 14.5V13H.5a.5.5 0 0 1 0-1H1V8.5H.5a.5.5 0 0 1 0-1H1V4H.5a.5.5 0 0 1 0-1H1zM2.5 1a.5.5 0 0 0-.5.5v13a.5.5 0 0 0 .5.5h12a.5.5 0 0 0 .5-.5v-13a.5.5 0 0 0-.5-.5z"/>
                        <path d="M13.5 6a.5.5 0 0 1 .5.5v3a.5.5 0 0 1-1 0v-3a.5.5 0 0 1 .5-.5M4.828 4.464a.5.5 0 0 1 .708 0l1.09 1.09a3.003 3.003 0 0 1 3.476 0l1.09-1.09a.5.5 0 1 1 .707.708l-1.09 1.09c.74 1.037.74 2.44 0 3.476l1.09 1.09a.5.5 0 1 1-.707.708l-1.09-1.09a3.002 3.002 0 0 1-3.476 0l-1.09 1.09a.5.5 0 1 1-.708-.708l1.09-1.09a3.003 3.003 0 0 1 0-3.476l-1.09-1.09a.5.5 0 0 1 0-.708zM6.95 6.586a2 2 0 1 0 2.828 2.828A2 2 0 0 0 6.95 6.586"/>
                    </svg>
                </div>
                <h6 class="text-white-50 text-uppercase fw-bold mb-1">Saldo Kas Saat Ini</h6>
                <h2 class="fw-bold mb-0">Rp @Model.Saldo.ToString("N0")</h2>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 text-center p-4" style="border-bottom: 5px solid #dc3545;">
                <div class="text-danger mb-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor" class="bi bi-box-arrow-up" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M3.5 6a.5.5 0 0 0-.5.5v8a.5.5 0 0 0 .5.5h9a.5.5 0 0 0 .5-.5v-8a.5.5 0 0 0-.5-.5h-2a.5.5 0 0 1 0-1h2A1.5 1.5 0 0 1 14 6.5v8a1.5 1.5 0 0 1-1.5 1.5h-9A1.5 1.5 0 0 1 2 14.5v-8A1.5 1.5 0 0 1 3.5 5h2a.5.5 0 0 1 0 1h-2z"/>
                        <path fill-rule="evenodd" d="M7.646.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 1.707V10.5a.5.5 0 0 1-1 0V1.707L5.354 3.854a.5.5 0 1 1-.708-.708l3-3z"/>
                    </svg>
                </div>
                <h6 class="text-muted text-uppercase fw-bold mb-1">Total Pengeluaran</h6>
                <h3 class="fw-bold text-dark mb-0">Rp @Model.TotalKeluar.ToString("N0")</h3>
            </div>
        </div>
    </div>
</div>