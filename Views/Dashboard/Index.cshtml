@model SIKAMTA.ViewModels.DashboardViewModel

@{
    Layout = "_AdminLayout";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            Dashboard
        </h2>
        
        <a asp-controller="Pengaturan" asp-action="Index" class="btn btn-outline-primary shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-gear-fill me-1" viewBox="0 0 16 16">
                <path d="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872l-.1-.34zM8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z"/>
            </svg>
            Pengaturan Mushola
        </a>
    </div>

    <div class="row mb-4 align-items-center bg-white p-3 shadow-sm rounded mx-0">
        <div class="col-md-2 text-center text-md-start">
            <img src="@Model.LogoPath" alt="Logo Mushola" class="img-fluid rounded-circle" style="max-height: 80px;" onerror="this.src='/images/default-logo.png';" />
        </div>
        <div class="col-md-10 text-center text-md-start mt-3 mt-md-0">
            <h4 class="fw-bold text-success mb-1">@Model.NamaMushola</h4>
            <p class="text-muted mb-0"><i class="fas fa-map-marker-alt"></i> @Model.AlamatMushola</p>
        </div>
    </div>

    <div class="row">

        <div class="col-md-4 mb-3">
            <div class="card border-success shadow h-100">
                <div class="card-body">
                    <h6 class="text-muted">
                        Total Pemasukan
                    </h6>
                    <h3 class="text-success">
                        Rp @Model.TotalMasuk.ToString("N0")
                    </h3>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card border-danger shadow h-100">
                <div class="card-body">
                    <h6 class="text-muted">
                        Total Pengeluaran
                    </h6>
                    <h3 class="text-danger">
                        Rp @Model.TotalKeluar.ToString("N0")
                    </h3>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card border-primary shadow h-100">
                <div class="card-body">
                    <h6 class="text-muted">
                        Saldo Kas
                    </h6>
                    <h3 class="text-primary">
                        Rp @Model.Saldo.ToString("N0")
                    </h3>
                </div>
            </div>
        </div>

    </div>

    <div class="card shadow mt-4">
        <div class="card-header">
            <strong>
                Grafik Pemasukan & Pengeluaran
            </strong>
        </div>
        <div class="card-body">
            <canvas id="kasChart"></canvas>
        </div>
    </div>

    <div class="mt-4 mb-5">
        <h5>
            Selamat Datang,
            @Context.Session.GetString("Nama")
        </h5>
        <p>
            Sistem Informasi Kas Mushola At-Taubah
        </p>
    </div>

</div>

<!-- Script Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
const ctx = document.getElementById('kasChart');

new Chart(ctx, {
    type: 'bar',
    data: {
        // Json.Serialize secara otomatis membuat array yang aman ["Jan", "Feb", ...]
        labels: @Html.Raw(Json.Serialize(Model.BulanLabels)),
        datasets: [
            {
                label: 'Pemasukan',
                data: @Html.Raw(Json.Serialize(Model.DataMasuk)),
                backgroundColor: 'rgba(25,135,84,0.7)'
            },
            {
                label: 'Pengeluaran',
                data: @Html.Raw(Json.Serialize(Model.DataKeluar)),
                backgroundColor: 'rgba(220,53,69,0.7)'
            }
        ]
    },
    options: {
        responsive: true,
        plugins: {
            legend: {
                position: 'top'
            }
        }
    }
});
</script>