@model SIKAMTA.Models.Kategori

@{
    Layout = "_AdminLayout";
}

<h2>Tambah Kategori</h2>

<hr />

<form method="post">

    <div class="mb-3">

        <label class="form-label">
            Nama Kategori
        </label>

        <input asp-for="NamaKategori"
               class="form-control" />

        <span asp-validation-for="NamaKategori"
              class="text-danger"></span>

    </div>

    <div class="mb-3">

        <label class="form-label">
            Jenis
        </label>

        <select asp-for="Jenis"
                class="form-control">

            <option value="">
                -- Pilih Jenis --
            </option>

            <option value="Masuk">
                Masuk
            </option>

            <option value="Keluar">
                Keluar
            </option>

        </select>

        <span asp-validation-for="Jenis"
              class="text-danger"></span>

    </div>

    <button type="submit"
            class="btn btn-success">
        Simpan
    </button>

    <a href="/Kategori"
       class="btn btn-secondary">
        Kembali
    </a>

</form>