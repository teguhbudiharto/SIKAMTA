@model SIKAMTA.Models.Kategori

@{
    Layout = "_AdminLayout";
}

<h2>Edit Kategori</h2>

<hr />

<form method="post">

    <input asp-for="Id" type="hidden" />

    <div class="mb-3">
        <label class="form-label">
            Nama Kategori
        </label>

        <input asp-for="NamaKategori"
               class="form-control" />
    </div>

    <div class="mb-3">

        <label class="form-label">
            Jenis
        </label>

        <select asp-for="Jenis"
                class="form-control">

            <option value="Masuk">
                Masuk
            </option>

            <option value="Keluar">
                Keluar
            </option>

        </select>

    </div>

    <button type="submit"
            class="btn btn-primary">
        Update
    </button>

    <a href="/Kategori"
       class="btn btn-secondary">
        Kembali
    </a>

</form>