@model List<SIKAMTA.Models.Kategori>

@{
    Layout = "_AdminLayout";
}

<h2>Data Kategori</h2>

<hr />

<a href="/Kategori/Create"
   class="btn btn-success mb-3">
    Tambah Kategori
</a>

<table class="table table-bordered">

    <thead>

        <tr>
            <th>ID</th>
            <th>Nama Kategori</th>
            <th>Jenis</th>
            <th>Aksi</th>
        </tr>

    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Id</td>

                <td>@item.NamaKategori</td>

                <td>@item.Jenis</td>

                <td>

                    <a href="/Kategori/Edit/@item.Id"
                       class="btn btn-warning btn-sm">
                        Edit
                    </a>

                    <a href="/Kategori/Delete/@item.Id"
                       class="btn btn-danger btn-sm">
                        Hapus
                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>